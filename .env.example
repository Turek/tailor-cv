# Anthropic API key — REQUIRED. Used for both CV/cover-letter generation and the
# kb-tokens token count. The CLI hard-fails with a clear message if this is unset.
# Get one at https://console.anthropic.com/ . Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl API key — required ONLY when you pass --url (to scrape a job ad page).
# Not needed for --text / --text-file. Get one at https://www.firecrawl.dev/ .
# Format: fc-...
FIRECRAWL_API_KEY=fc-...

# Claude model used for generation. Overridable; default is claude-sonnet-4-6.
# Can also be overridden per-run with `generate --model <id>`.
TAILORCV_MODEL=claude-sonnet-4-6

# Soft limit (tokens) for the knowledge base. `make tokens` and `generate` warn
# (do not fail) when the KB exceeds this. Larger KBs cost more and may dilute quality.
TAILORCV_TOKEN_BUDGET=70000

# Hard cap on output tokens per generated document (CV or cover letter).
TAILORCV_MAX_OUTPUT_TOKENS=4096
