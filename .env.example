# Anthropic API key — REQUIRED. Used for CV/cover-letter generation when
# --provider anthropic (the default) and ALWAYS for the kb-tokens token count
# (the budget check uses Anthropic's tokenizer regardless of provider).
# Get one at https://console.anthropic.com/ . Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key — required only when --provider google. Get a free key at
# https://aistudio.google.com/apikey . Format: AIza...
GEMINI_API_KEY=

# Default LLM backend. One of: anthropic | google. Override per-run with
# --provider on `tailorcv generate`.
TAILORCV_PROVIDER=anthropic

# Firecrawl API key — required ONLY when you pass --url (to scrape a job ad).
# Not needed for --text / --text-file. Format: fc-...
FIRECRAWL_API_KEY=fc-...

# Soft limit (tokens) for the knowledge base. `make tokens` and `generate` warn
# (do not fail) when the KB exceeds this.
TAILORCV_TOKEN_BUDGET=70000

# Hard cap on output tokens per generated document (CV or cover letter).
TAILORCV_MAX_OUTPUT_TOKENS=4096
